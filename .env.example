# Hugging Face cache root (HF_HOME). Models download to STORAGE/hub/
# Example (Windows): E:/hf_cache
# Example (Linux):   /data/huggingface
STORAGE=

# HuggingFace access token — required for gated models
# (stabilityai/stable-diffusion-2-1-base needs login + license acceptance at
#  https://huggingface.co/stabilityai/stable-diffusion-2-1)
# Generate a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: SwiftEdit release weights folder (default: swiftedit_weights in repo)
# SWIFTEDIT_WEIGHTS_ROOT=swiftedit_weights
